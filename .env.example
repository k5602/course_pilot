# Course Pilot Configuration
# Copy this file to .env and fill in your values

# Database path (default: course_pilot.db)
DATABASE_URL=course_pilot.db


# Gemini API key (optional - for AI companion and exams)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# LLM model (default: gemini-2.5-flash)
# LLM_MODEL=gemini-2.5-flash

# Discord Rich Presence client ID (optional)
# DISCORD_CLIENT_ID=
